# ============================================
# WA Unified System — Environment Configuration
# ============================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# ── Database ──────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3308
DB_USER=root
DB_PASSWORD=wa_unified_2026
DB_NAME=wa_db

# ── Arm Hardware Defaults ─────────────────────
# (overridden per-arm from DB arms table)
ARM_SERVICE_URL=http://127.0.0.1:8082/MyWcfService/getstring
ARM_COM_PORT=COM6
ARM_Z_DOWN=10
ARM_MOVE_DELAY=0.3
ARM_PRESS_DELAY=0.15
ARM_DIGIT_DELAY=0.5

# ── Camera Defaults ───────────────────────────
CAMERA_ID=0
CAMERA_WARMUP=5

# ── PAS Integration (WA → PAS callbacks) ─────
# URL for reporting withdrawal results back to PAS
PAS_API_URL=https://apisix.mxlpmsstaging.com/service/payment/api/external
PAS_API_KEY=your_pas_api_key_here
PAS_TENANT_ID=apexnova

# ── WA API Auth (PAS → WA requests) ──────────
# Required: if empty, protected endpoints return 503
WA_API_KEY=your_wa_api_key_here
WA_TENANT_ID=apexnova
