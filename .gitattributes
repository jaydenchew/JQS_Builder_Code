# Auto-detect text files and normalise line endings to LF in the repo.
# On Windows checkout, autocrlf=true turns them into CRLF for the working
# tree; on commit they're stored back as LF. Without this file, git emits
# "LF will be replaced by CRLF" warnings for files that drifted on a
# previous machine, even when there's no real content change.
* text=auto

# Treat known-binary files explicitly so git never tries to normalise them.
# Without these rules `* text=auto` relies on git's content heuristic; the
# explicit list documents intent and protects large files (e.g. EasyOCR
# model weights ~100 MB) from any accidental mangling.
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary
*.exe    binary
*.dll    binary
*.pdb    binary
*.pth    binary
*.umd.min.js binary

# Windows-specific scripts force CRLF so Notepad / cmd.exe behave.
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf

# Shell scripts force LF (they need it to run on linux / WSL / docker).
*.sh     text eol=lf
