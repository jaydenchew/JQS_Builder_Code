# 敏感配置
.env
.env.*
!.env.example

# 数据库种子（含真实凭证 — 测试数据也不推）
db/seed.sql
db/seed_*.sql
!db/seed.example.sql
# 例外：per-bank flow seeds 不含凭证或坐标，可以跟踪
!db/seed_bank_*.sql

# 数据库备份（本地 mysqldump 输出，含所有数据，不上传）
db_backups/

# 大文件 / 二进制
# ngrok 是每台机器自己配（登录 token / 隧道 URL 不同），保持忽略
ngrok.exe
ngrok-*.zip
# 下列运行时产物不跟踪：.pdb 是调试符号（安装不需要），
# .InstallLog/.InstallState 是 InstallUtil 每次安装生成的记录
arm_service/service/*.pdb
arm_service/service/*.InstallLog
arm_service/service/*.InstallState
# CHECK_SCREEN 参考图：每台机器的相机角度、灯光、手机摆位都不一样，
# 跨机器复用会直接导致 SSIM 对不上。每台机器自己在 Builder 里截图即可。
references/
# 注意：models/、arm_service/service/*.exe、*.dll、deploy/nssm.exe、
# deploy/tesseract-setup.exe、arm_service/VC_redist.x86.exe 全部纳入跟踪，
# 新机器 git clone 后即可直接 deploy/install_service.bat 完成安装。

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
.Python
venv/
env/
.venv/

# Claude / Agent 本地
.claude/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
deploy/logs/

# OS
Thumbs.db
.DS_Store
desktop.ini
